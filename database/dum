import api from "./api";

const freelancerService = {
  getFreelancerProfile(id) {
    return api.get(`/freelancers/${id}`).then(res => res.data);
  },

  updateFreelancerProfile(id, data) {
    return api.put(`/freelancers/${id}`, data).then(res => res.data);
  },

  // ---------- PORTFOLIO APIS (OPTION B) ----------
  getPortfolio(id) {
    return api.get(`/freelancers/${id}/portfolio`).then(res => res.data);
  },

  addPortfolio(id, data) {
    return api.post(`/freelancers/${id}/portfolio`, data).then(res => res.data);
  },

  updatePortfolio(portfolioId, data) {
    return api.put(`/freelancers/portfolio/${portfolioId}`, data).then(res => res.data);
  },

  deletePortfolio(portfolioId) {
    return api.delete(`/freelancers/portfolio/${portfolioId}`);
  }
};

export default freelancerService;
