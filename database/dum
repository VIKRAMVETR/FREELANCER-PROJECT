import api from "./api";

const freelancerService = {
  // Get full profile (skills + portfolio + ratings)
  getFreelancerProfile: async (freelancerId) => {
    const res = await api.get(`/api/freelancers/${freelancerId}/profile`);
    return res.data;
  },

  // UPDATE freelancer profile - FIXED ✔
  updateFreelancerProfile: async (freelancerId, profileData) => {
    const payload = {
      ...profileData,
      userId: freelancerId,                        // backend requires userId
      title: profileData.title || "Freelancer"     // backend requires title
    };

    const res = await api.put(`/api/freelancers/${freelancerId}`, payload);
    return res.data;
  },

  // Portfolio functions (these match your backend)
  getFreelancerPortfolio: async (freelancerId) => {
    const res = await api.get(`/api/freelancers/${freelancerId}/portfolio`);
    return res.data;
  },

  addPortfolioItem: async (freelancerId, item) => {
    const res = await api.post(`/api/freelancers/${freelancerId}/portfolio`, item);
    return res.data;
  },

  deletePortfolioItem: async (itemId) => {
    const res = await api.delete(`/api/freelancers/portfolio/${itemId}`);
    return res.data;
  },
};

export default freelancerService;
